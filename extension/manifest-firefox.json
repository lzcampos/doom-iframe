{
  "manifest_version": 3,
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "webdoom-embed@doom-iframe.local",
      "strict_min_version": "115.0"
    }
  },
  "name": "WebDOOM (embed)",
  "version": "1.0.0",
  "description": "Play WebDOOM in the side panel, inject a floating box, or open a tab. Bundled wasm; bypasses most page CSP via side panel.",
  "permissions": ["scripting", "storage", "contextMenus", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "WebDOOM — open side panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "WebDOOM",
    "default_panel": "sidepanel.html",
    "default_icon": "icons/icon48.png",
    "open_at_install": false
  },
  "commands": {
    "toggle-page-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle WebDOOM overlay on the current page"
    },
    "open-webdoom-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Open WebDOOM in a new tab"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["doom/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
